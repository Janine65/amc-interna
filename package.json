{
  "name": "amc-interna",
  "version": "4.4.5",
  "description": "Auto-Moto-Club Administration: Frontend für die interne Applikation des Vereins.",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "nx": "nx",
    "start": "NODE_OPTIONS=--no-deprecation nx serve",
    "start:dev": "NODE_OPTIONS=--no-deprecation nx serve --watch",
    "build": "nx run-many -t build --configuration development --verbose",
    "watch": "nx build --watch --configuration development",
    "test": "nx test",
    "lint": "nx lint",
    "postversion": "git push && git push --tags && pnpm docker:dev && pnpm docker:dev:run",
    "docker": "APP_VERSION=$(node -p \"require('./package.json').version\") BACKEND_VERSION=$(sed -nE 's/^PACKAGE_VERSION[[:space:]]*=[[:space:]]*\"([^\"]+)\".*/\\1/p' ../amc-backend-py/app/core/config.py) sh -c 'docker compose build && docker push janine65/amcbackend:latest && docker push janine65/amcbackend:$BACKEND_VERSION && docker push janine65/amcinternal:latest && docker push janine65/amcinternal:$APP_VERSION'",
    "docker:dev": "sh -c 'docker compose -f docker-compose-test.yml build'",
    "docker:dev:run": "sh -c 'docker compose -f docker-compose-test.yml down && docker compose -f docker-compose-test.yml up -d'"
  },
  "author": "Janine Franken",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@angular-devkit/build-angular": "21.2.11",
    "@angular/animations": "21.2.13",
    "@angular/cdk": "21.2.11",
    "@angular/cli": "21.2.11",
    "@angular/common": "21.2.13",
    "@angular/compiler": "21.2.13",
    "@angular/compiler-cli": "21.2.13",
    "@angular/core": "21.2.13",
    "@angular/forms": "21.2.13",
    "@angular/material": "21.2.11",
    "@angular/platform-browser": "21.2.13",
    "@angular/platform-browser-dynamic": "21.2.13",
    "@angular/router": "21.2.13",
    "@primeuix/themes": "^2.0.3",
    "chart.js": "4.5.1",
    "primeicons": "7.0.0",
    "primeng": "21.1.7",
    "quill": "^2.0.3",
    "rxjs": "~7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.2.11",
    "@angular-devkit/schematics": "21.2.11",
    "@angular-eslint/builder": "21.4.0",
    "@angular-eslint/eslint-plugin": "21.4.0",
    "@angular-eslint/eslint-plugin-template": "21.4.0",
    "@angular-eslint/schematics": "21.4.0",
    "@angular-eslint/template-parser": "21.4.0",
    "@angular/language-service": "^21.2.13",
    "@nx/angular": "22.7.2",
    "@nx/devkit": "22.7.2",
    "@nx/nx-darwin-arm64": "22.7.2",
    "@nx/workspace": "22.7.2",
    "@schematics/angular": "21.2.11",
    "@types/jasmine": "5.1.7",
    "@types/jest": "29.5.14",
    "@types/node": "22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@typescript-eslint/utils": "^8.33.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "5.6.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "nx": "22.7.2",
    "tailwindcss": "3",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
